+          NSError *jsonErr = nil;
+          NSData *jsonData =
+              [NSJSONSerialization dataWithJSONObject:val options:0 error:&jsonErr];
+          if (jsonData != nil && jsonErr == nil) {
+            valStr = [[NSString alloc] initWithData:jsonData encoding:NSUTF8StringEncoding];
+          } else {
+            valStr = [val description];
+          }
+        } else if ([val isKindOfClass:[NSData class]]) {
+          valStr = [[NSString alloc] initWithData:(NSData *)val encoding:NSUTF8StringEncoding] ?: [val description];
+        } else {
+          valStr = [val description];
+        }
+        [userInfoDump appendFormat:@"%@=%@ | ", key, valStr ?: @"<nil>"];
+      }
+    }
+  }
+  NSString *finalDump = ([userInfoDump length] > 0) ? userInfoDump : @"<empty>";
+  NSLog(@"[RNFB DEBUG] auth error: domain=%@ code=%ld userInfo=%@", nsErrorDomain, (long)nsErrorCode, finalDump);
+
