 - (void)promiseRejectAuthException:(RCTPromiseRejectBlock)reject error:(NSError *)error {
   NSDictionary *jsError = [self getJSError:error];
 
+  // DEBUG: surface the raw NSError userInfo (including Identity Toolkit response body)
+  // through the JS bridge so the actual backend error reason is visible in Metro logs.
+  NSMutableString *userInfoDump = [NSMutableString string];
+  NSInteger nsErrorCode = -1;
